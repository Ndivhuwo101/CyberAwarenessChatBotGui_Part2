<Window x:Class="CyberSecurityBotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="500"
        Width="800"
        Background="Black">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="CYBERSECURITY AWARENESS BOT"
                   Foreground="Cyan"
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <!-- Chat Area -->
        <RichTextBox Name="rtbChat"
                     Grid.Row="1"
                     Background="Black"
                     Foreground="White"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,10,0,10"/>

        <!-- Bottom Input Area -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal">

            <TextBox Name="txtUserInput"
                     Width="650"
                     Height="35"
                     FontSize="14"
                     Margin="0,0,10,0"/>

            <Button Name="btnSend"
                    Content="Send"
                    Width="100"
                    Height="35"
                    Background="Cyan"
                    Click="btnSend_Click"/>
        </StackPanel>

    </Grid>
</Window>